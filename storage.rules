rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isAuthenticated() {
      return request.auth != null;
    }

    function userDocExists() {
      return firestore.exists(/databases/(default)/documents/users/$(request.auth.uid));
    }

    function isSuperAdmin() {
      return isAuthenticated()
        && userDocExists()
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'super_admin';
    }

    // Model approval documents (PDF / images)
    // Primary: super_admin via Firestore profile.
    // Fallback: any signed-in user (Products page is super-admin-only in the app).
    match /products/{modelId}/model-approval/{fileName} {
      allow read: if true;
      allow write: if isSuperAdmin() || isAuthenticated();
    }

    match /products/{modelId}/product-image/{fileName} {
      allow read: if true;
      allow write: if isSuperAdmin() || isAuthenticated();
    }

    // RC / VCT profile documents — folders from rcCertificateUpload + vctDocumentUpload.
    // PAN card read is Super Admin only; all other user folders are public read.
    match /users/{userId}/{docKind}/{fileName} {
      allow read: if docKind != 'pan-card' || isSuperAdmin();
      allow write: if isAuthenticated();
    }

    // RC fleet documents — folders: rc, insurance, pollution, f2-weight, photo.
    match /vehicles/{vehicleId}/{kind}/{fileName} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Customer photos and per-device images.
    match /customers/{customerId}/{folder}/{fileName} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Verification evidence — folders from verificationDeviceImages + verificationRvDeviceImages.
    // Wildcard avoids 403 when new RV/OV image slots are added (e.g. verification-seal-image).
    match /siteCalibrations/{recordId}/{folder}/{fileName} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /walletTopUps/{topUpId}/screenshot/{fileName} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /automationWorker/captcha/{fileName} {
      allow read, write: if isSuperAdmin();
    }
  }
}
