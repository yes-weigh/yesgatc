<Window x:Class="Yesgatc.CertificateWorker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="YesGATC Certificate Worker"
        Height="720"
        Width="1100"
        MinHeight="520"
        MinWidth="880"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgAppBrush}"
        FontFamily="Segoe UI">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- Queue -->
        <Border Grid.Column="0"
                Style="{StaticResource GlassPanel}"
                Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="18,16,18,6">
                    <Button x:Name="RefreshButton"
                            Content="Refresh"
                            Style="{StaticResource SecondaryButton}"
                            DockPanel.Dock="Right"
                            Margin="10,0,0,0"
                            Click="RefreshButton_Click"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Queue" Style="{StaticResource SectionTitle}"/>
                        <TextBlock Text="Submitted and approved jobs across all RCs"
                                   FontSize="12"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </DockPanel>

                <TextBlock x:Name="QueueCountText"
                           Grid.Row="1"
                           Margin="18,0,18,8"
                           FontSize="12"
                           Foreground="{StaticResource TextMutedBrush}"
                           Text="0 jobs pending"/>

                <DataGrid x:Name="JobsGrid"
                          Grid.Row="2"
                          Margin="12,0,12,14"
                          IsReadOnly="True"
                          RowStyle="{StaticResource QueueDataGridRow}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="RC"
                                            Binding="{Binding RcCenterName}"
                                            Width="*"
                                            ElementStyle="{StaticResource DataGridCellText}"/>
                        <DataGridTextColumn Header="Customer"
                                            Binding="{Binding CustomerName}"
                                            Width="1.2*"
                                            ElementStyle="{StaticResource DataGridCellText}"/>
                        <DataGridTextColumn Header="Serial"
                                            Binding="{Binding SerialNumber}"
                                            Width="0.9*"
                                            ElementStyle="{StaticResource DataGridCellMono}"/>
                        <DataGridTextColumn Header="Status"
                                            Binding="{Binding StatusLabel}"
                                            Width="0.8*"
                                            ElementStyle="{StaticResource DataGridCellMuted}"/>
                        <DataGridTextColumn Header="Next"
                                            Binding="{Binding NextStepLabel}"
                                            Width="1*"
                                            ElementStyle="{StaticResource DataGridCellMuted}"/>
                        <DataGridTextColumn Header="Retry"
                                            Binding="{Binding RetryBadge}"
                                            Width="0.7*"
                                            ElementStyle="{StaticResource DataGridCellRetryBadge}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel x:Name="EmptyStateText"
                            Grid.Row="2"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Margin="24"
                            Visibility="Collapsed">
                    <TextBlock x:Name="EmptyStateTitleText"
                               Text="No pending jobs"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextMainBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="EmptyStateBodyText"
                               Text="Sign in to load the queue."
                               FontSize="13"
                               Foreground="{StaticResource TextMutedBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,6,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Sidebar -->
        <StackPanel Grid.Column="2">
            <TextBlock Text="Certificate Worker"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TitleGradientBrush}"
                       Margin="0,0,0,14"/>

            <Border Style="{StaticResource GlassPanel}"
                    Padding="16"
                    Margin="0,0,0,12">
                <Expander x:Name="SignInExpander"
                          Style="{StaticResource GlassExpander}"
                          IsExpanded="False">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="SignInStatusDot"
                                     Style="{StaticResource StatusDot}"
                                     Margin="0,0,8,0"/>
                            <StackPanel>
                                <TextBlock Text="Account"
                                           FontSize="11"
                                           Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBlock x:Name="SignInSummaryText"
                                           Text="Not signed in"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextMainBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Expander.Header>

                    <StackPanel Margin="0,6,0,0">
                        <TextBlock Text="YesGATC" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="AadharBox"
                                     Grid.Column="0"
                                     Style="{StaticResource GlassTextBox}"/>
                            <TextBox x:Name="PasswordBox"
                                     Grid.Column="2"
                                     Style="{StaticResource GlassTextBox}"/>
                        </Grid>

                        <Button x:Name="SignInButton"
                                Content="Sign in"
                                Style="{StaticResource PrimaryButton}"
                                HorizontalAlignment="Stretch"
                                Margin="0,0,0,14"
                                Click="SignInButton_Click"/>

                        <TextBlock Text="DOCA" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                        <TextBox x:Name="DocaEmailBox"
                                 Style="{StaticResource GlassTextBox}"
                                 Margin="0,0,0,8"/>
                        <TextBox x:Name="DocaPasswordBox"
                                 Style="{StaticResource GlassTextBox}"
                                 Margin="0,0,0,14"/>

                        <DockPanel Margin="0,0,0,4">
                            <TextBlock x:Name="CaptchaApiKeyHint"
                                       DockPanel.Dock="Right"
                                       FontSize="11"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       VerticalAlignment="Center"
                                       Text=""/>
                            <TextBlock Text="Captcha AI Key"
                                       Style="{StaticResource FieldLabel}"/>
                        </DockPanel>
                        <TextBox x:Name="CaptchaApiKeyBox"
                                 Style="{StaticResource GlassTextBox}"
                                 Margin="0,0,0,12"/>

                        <Button x:Name="SaveCredsButton"
                                Content="Save Credentials"
                                Style="{StaticResource SecondaryButton}"
                                HorizontalAlignment="Stretch"
                                Click="SaveCredsButton_Click"/>
                    </StackPanel>
                </Expander>
            </Border>

            <Border Style="{StaticResource GlassPanel}"
                    Padding="16"
                    Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Auto worker"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextMutedBrush}"/>
                    <TextBlock x:Name="AutoWorkerStatusText"
                               Text="Waiting to sign in…"
                               FontSize="12"
                               Foreground="{StaticResource TextMainBrush}"
                               TextWrapping="Wrap"
                               Margin="0,6,0,0"/>
                    <CheckBox x:Name="DocaFillOnlyCheckBox"
                              Content="Fill only (do not submit on DOCA)"
                              Margin="0,10,0,0"
                              FontSize="12"
                              Foreground="{StaticResource TextMainBrush}"
                              Checked="DocaFillOnlyCheckBox_Changed"
                              Unchecked="DocaFillOnlyCheckBox_Changed"/>
                    <TextBlock Text="When checked, automation fills the IC form but does not click Generate Certificate or update Firebase. Uncheck for full runs."
                               FontSize="10"
                               Foreground="{StaticResource TextMutedBrush}"
                               TextWrapping="Wrap"
                               Margin="22,4,0,0"/>
                    <TextBlock Text="Session probe (minutes)"
                               Style="{StaticResource FieldLabel}"
                               Margin="0,12,0,4"/>
                    <TextBox x:Name="DocaSessionProbeMinutesBox"
                             Style="{StaticResource GlassTextBox}"
                             LostFocus="DocaSessionProbeMinutesBox_LostFocus"/>
                    <TextBlock Text="While logged in, open IC verification on this interval to detect DOCA logout and measure session length. 0 = disabled."
                               FontSize="10"
                               Foreground="{StaticResource TextMutedBrush}"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource GlassPanel}"
                    Padding="16"
                    VerticalAlignment="Stretch">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <Ellipse x:Name="StatusStateDot"
                                 Style="{StaticResource StatusDot}"
                                 Margin="0,0,8,0"/>
                        <TextBlock x:Name="StatusStateText"
                                   Text="Idle"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="StatusTimestampText"
                                   FontSize="11"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   VerticalAlignment="Center"
                                   Margin="8,0,0,0"/>
                    </StackPanel>

                    <TextBlock x:Name="StatusText"
                               Grid.Row="1"
                               Text="Sign in to start."
                               TextWrapping="Wrap"
                               FontSize="13"
                               LineHeight="19"
                               Foreground="{StaticResource TextMainBrush}"
                               Margin="0,0,0,10"/>

                    <TextBlock Grid.Row="2"
                               Text="Activity"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextMutedBrush}"
                               Margin="0,0,0,4"/>

                    <ListBox x:Name="ActivityLogList"
                             Grid.Row="3"
                             MinHeight="120"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             FontSize="12"
                             Foreground="{StaticResource TextMutedBrush}"
                             MouseDoubleClick="ActivityLogList_MouseDoubleClick">
                        <ListBox.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Copy Selected" Click="CopyLogItem_Click"/>
                                <MenuItem Header="Copy All Logs" Click="CopyAllLogs_Click"/>
                                <MenuItem Header="Open Log File" Click="OpenLogFile_Click"/>
                            </ContextMenu>
                        </ListBox.ContextMenu>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0,2"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <ContentPresenter/>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="ToolTip" Value="{Binding}"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" TextWrapping="Wrap"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </StackPanel>
    </Grid>
</Window>
