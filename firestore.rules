rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function role() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function validAadhar(data) {
      return data.aadhar is string && data.aadhar.size() == 12;
    }

    function validAadharId(aadhar) {
      return aadhar is string && aadhar.size() == 12;
    }

    function isAuthenticated() { return request.auth != null; }
    function isSuperAdmin()    { return isAuthenticated() && role() == 'super_admin'; }
    function isRCAdmin()       { return isAuthenticated() && role() == 'rc_admin'; }
    function isVCT()           { return isAuthenticated() && role() == 'vct'; }

    function requestUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function vctRcId() {
      return requestUser().rcId;
    }

    function isOperationalVct() {
      return isVCT()
        && vctApprovalStatus(requestUser()) == 'approved'
        && requestUser().get('active', true) != false;
    }

    function vctApprovalStatus(data) {
      return data.get('approvalStatus', 'approved');
    }

    function validVerificationApplicationNumber(data) {
      return data.get('applicationNumber', '') is string
        && data.applicationNumber.matches('^VC/[0-9]{2}/[0-9]+$');
    }

    function verificationApplicationNumberUnchanged() {
      return request.resource.data.get('applicationNumber', null)
        == resource.data.get('applicationNumber', null);
    }

    function zohoRvInvoicingEnabled() {
      return get(/databases/$(database)/documents/appSettings/global).data.get('zohoRvInvoicingEnabled', true) != false;
    }

    function rvSubmitRequiresZohoCustomer(data) {
      return data.get('verificationType', '') == 'RV'
        && verificationRecordStatus(data) == 'submitted'
        && zohoRvInvoicingEnabled();
    }

    function rcHasZohoCustomerId(rcId) {
      let zohoId = get(/databases/$(database)/documents/users/$(rcId)).data.get('zohoId', '');
      return zohoId is string && zohoId.size() >= 10;
    }

    function verificationZohoFieldsUnchanged() {
      return request.resource.data.get('zohoInvoiceId', null) == resource.data.get('zohoInvoiceId', null)
        && request.resource.data.get('zohoInvoiceNumber', null) == resource.data.get('zohoInvoiceNumber', null)
        && request.resource.data.get('zohoInvoiceStatus', null) == resource.data.get('zohoInvoiceStatus', null)
        && request.resource.data.get('zohoCustomerId', null) == resource.data.get('zohoCustomerId', null)
        && request.resource.data.get('zohoCustomerName', null) == resource.data.get('zohoCustomerName', null)
        && request.resource.data.get('zohoInvoiceTotal', null) == resource.data.get('zohoInvoiceTotal', null)
        && request.resource.data.get('zohoOrganizationId', null) == resource.data.get('zohoOrganizationId', null)
        && request.resource.data.get('zohoPushStatus', null) == resource.data.get('zohoPushStatus', null)
        && request.resource.data.get('zohoPushedAt', null) == resource.data.get('zohoPushedAt', null)
        && request.resource.data.get('zohoPushError', null) == resource.data.get('zohoPushError', null)
        && request.resource.data.get('zohoCustomerPaymentId', null) == resource.data.get('zohoCustomerPaymentId', null)
        && request.resource.data.get('zohoCustomerPaymentStatus', null) == resource.data.get('zohoCustomerPaymentStatus', null)
        && request.resource.data.get('zohoCustomerPaymentAmountInr', null) == resource.data.get('zohoCustomerPaymentAmountInr', null)
        && request.resource.data.get('zohoExpenseId', null) == resource.data.get('zohoExpenseId', null)
        && request.resource.data.get('zohoExpenseStatus', null) == resource.data.get('zohoExpenseStatus', null)
        && request.resource.data.get('zohoExpenseAmountInr', null) == resource.data.get('zohoExpenseAmountInr', null)
        && request.resource.data.get('zohoSettlementStatus', null) == resource.data.get('zohoSettlementStatus', null)
        && request.resource.data.get('zohoSettlementError', null) == resource.data.get('zohoSettlementError', null)
        && request.resource.data.get('zohoSettledAt', null) == resource.data.get('zohoSettledAt', null)
        && request.resource.data.get('zohoInvoiceReferenceNumber', null) == resource.data.get('zohoInvoiceReferenceNumber', null)
        && request.resource.data.get('zohoInvoiceReferenceSynced', null) == resource.data.get('zohoInvoiceReferenceSynced', null)
        && request.resource.data.get('zohoInvoiceReferenceSyncedAt', null) == resource.data.get('zohoInvoiceReferenceSyncedAt', null)
        && request.resource.data.get('zohoInvoiceReferenceSyncError', null) == resource.data.get('zohoInvoiceReferenceSyncError', null);
    }

    // ── users ─────────────────────────────────────────────────────
    match /users/{uid} {

      allow get: if isAuthenticated() && request.auth.uid == uid;

      allow get: if isOperationalVct()
        && uid == vctRcId()
        && resource.data.role == 'rc_admin';

      allow get: if isOperationalVct()
        && resource.data.role == 'vct'
        && resource.data.rcId == vctRcId();

      allow read, write: if isSuperAdmin();

      allow read: if isRCAdmin()
        && resource.data.role == 'vct'
        && resource.data.rcId == request.auth.uid;

      allow create: if isAuthenticated()
        && request.auth.uid == uid
        && validAadhar(request.resource.data);

      allow create: if isRCAdmin()
        && request.resource.data.role == 'vct'
        && request.resource.data.rcId == request.auth.uid
        && validAadhar(request.resource.data)
        && request.resource.data.approvalStatus == 'pending';

      allow update: if isRCAdmin()
        && request.auth.uid == uid
        && resource.data.role == 'rc_admin'
        && request.resource.data.role == 'rc_admin'
        && request.resource.data.aadhar == resource.data.aadhar
        && validAadhar(request.resource.data)
        && request.resource.data.get('rcCode', null) == resource.data.get('rcCode', null)
        && request.resource.data.get('zohoId', null) == resource.data.get('zohoId', null)
        && request.resource.data.get('zohoExpenseAccountId', null) == resource.data.get('zohoExpenseAccountId', null)
        && request.resource.data.get('zohoExpenseAccountName', null) == resource.data.get('zohoExpenseAccountName', null)
        && request.resource.data.get('panCard', null) == resource.data.get('panCard', null)
        && request.resource.data.get('panCardUrl', null) == resource.data.get('panCardUrl', null)
        && request.resource.data.get('panCardPath', null) == resource.data.get('panCardPath', null)
        && request.resource.data.get('panCardName', null) == resource.data.get('panCardName', null)
        && request.resource.data.get('panCardContentType', null) == resource.data.get('panCardContentType', null);

      allow update: if isRCAdmin()
        && resource.data.role == 'vct'
        && resource.data.rcId == request.auth.uid
        && request.resource.data.role == 'vct'
        && request.resource.data.rcId == request.auth.uid
        && request.resource.data.aadhar == resource.data.aadhar
        && validAadhar(request.resource.data)
        && vctApprovalStatus(request.resource.data) == vctApprovalStatus(resource.data)
        && request.resource.data.get('approvedAt', null) == resource.data.get('approvedAt', null)
        && request.resource.data.get('approvedByUid', null) == resource.data.get('approvedByUid', null);

      allow delete: if isRCAdmin()
        && resource.data.role == 'vct'
        && resource.data.rcId == request.auth.uid
        && vctApprovalStatus(resource.data) == 'pending';
    }

    // ── aadharIndex (global duplicate Aadhar lookup) ───────────────
    match /aadharIndex/{aadhar} {
      allow get: if isSuperAdmin() || isRCAdmin();

      allow create: if validAadharId(aadhar)
        && (isSuperAdmin() || isRCAdmin())
        && request.resource.data.uid is string
        && request.resource.data.role is string;

      allow delete: if isSuperAdmin() || isRCAdmin();
    }

    // ── rcVcts (RC technician roster index) ───────────────────────
    match /rcVcts/{rcId} {
      allow read, write: if isSuperAdmin();

      match /members/{vctUid} {
        allow read, write: if isSuperAdmin();
        allow read: if isRCAdmin() && request.auth.uid == rcId;
        allow read: if isOperationalVct() && rcId == vctRcId();
        allow create: if isRCAdmin() && request.auth.uid == rcId;
        allow update: if isRCAdmin() && request.auth.uid == rcId;
        allow delete: if isRCAdmin()
          && request.auth.uid == rcId
          && vctApprovalStatus(resource.data) == 'pending';
      }
    }

    function isAdminManagedProduct() {
      return !('managedByRole' in resource.data)
        || resource.data.managedByRole == 'super_admin';
    }

    // ── products ──────────────────────────────────────────────────
    match /products/{productId} {
      allow list: if isAuthenticated();
      allow get: if isSuperAdmin()
        || (isAuthenticated() && isAdminManagedProduct());
      allow create, update, delete: if isSuperAdmin();
    }

    // ── jobs ───────────────────────────────────────────────────────────
    match /jobs/{jobId} {
      allow read:   if isAuthenticated();
      allow create: if isSuperAdmin() || isRCAdmin();
      allow update: if isAuthenticated();
      allow delete: if isSuperAdmin();
    }

    // ── certificates ───────────────────────────────────────────────
    match /certificates/{certId} {
      allow read:  if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // ── vehicles (RC-managed) ─────────────────────────────────────
    match /vehicles/{vehicleId} {
      allow read, write: if isSuperAdmin();

      allow read: if isRCAdmin() && resource.data.rcId == request.auth.uid;

      allow create: if isRCAdmin()
        && request.resource.data.rcId == request.auth.uid;

      allow update: if isRCAdmin()
        && resource.data.rcId == request.auth.uid
        && request.resource.data.rcId == request.auth.uid;

      // RC cannot delete vehicles once registered; Super Admin may remove records.
    }

    // ── customers (RC-managed) ────────────────────────────────────
    match /customers/{customerId} {
      allow read, write: if isSuperAdmin();

      allow read: if isRCAdmin() && resource.data.rcId == request.auth.uid;

      allow read: if isOperationalVct() && resource.data.rcId == vctRcId();

      allow create: if isRCAdmin()
        && request.resource.data.rcId == request.auth.uid;

      allow create: if isOperationalVct()
        && request.resource.data.rcId == vctRcId()
        && request.resource.data.get('createdByUid', '') == request.auth.uid;

      allow update: if isRCAdmin()
        && resource.data.rcId == request.auth.uid
        && request.resource.data.rcId == request.auth.uid;

      allow update: if isOperationalVct()
        && resource.data.rcId == vctRcId()
        && request.resource.data.rcId == vctRcId();

      // RC cannot delete customers once registered; Super Admin may remove records.
    }

    // ── site calibrations (RC-managed verification requests) ───────
    match /siteCalibrations/{recordId} {
      function verificationStatusCorrupted(data) {
        let status = data.get('status', 'draft');
        return status is string
          && status.matches('.*System\\.Collections\\.Generic\\.Dictionary.*');
      }

      function verificationTimestampLooksValid(value) {
        return value is string
          && value.size() >= 20
          && !value.matches('.*System\\.Collections\\.Generic\\.Dictionary.*');
      }

      function verificationCertificateNumberLooksValid(data) {
        let certificateNumber = data.get('certificateNumber', '');
        return certificateNumber is string
          && certificateNumber.size() > 0
          && !certificateNumber.matches('.*System\\.Collections\\.Generic\\.Dictionary.*');
      }

      function inferredVerificationRecordStatus(data) {
        return verificationTimestampLooksValid(data.get('certifiedAt', '')) ? 'certified'
          : verificationCertificateNumberLooksValid(data) ? 'certified'
          : verificationTimestampLooksValid(data.get('approvedAt', '')) ? 'approved'
          : verificationTimestampLooksValid(data.get('submittedAt', '')) ? 'submitted'
          : 'draft';
      }

      function verificationRecordStatus(data) {
        return verificationStatusCorrupted(data)
          ? inferredVerificationRecordStatus(data)
          : data.get('status', 'draft');
      }

      function vctOwnsVerification(data) {
        return data.get('createdByUid', '') == request.auth.uid
          || data.get('vctId', '') == request.auth.uid;
      }

      allow read: if isSuperAdmin();
      allow create, update: if isSuperAdmin();
      allow delete: if isSuperAdmin()
        && verificationRecordStatus(resource.data) == 'draft';

      allow read: if isRCAdmin() && resource.data.rcId == request.auth.uid;

      allow read: if isOperationalVct()
        && resource.data.rcId == vctRcId()
        && vctOwnsVerification(resource.data);

      // RC creates draft records only; submit is a separate update.
      allow create: if isRCAdmin()
        && request.resource.data.rcId == request.auth.uid
        && verificationRecordStatus(request.resource.data) == 'draft'
        && validVerificationApplicationNumber(request.resource.data);

      allow create: if isOperationalVct()
        && request.resource.data.rcId == vctRcId()
        && request.resource.data.get('createdByUid', '') == request.auth.uid
        && request.resource.data.get('vctId', '') == request.auth.uid
        && request.resource.data.get('performedBy', '') == 'vct'
        && verificationRecordStatus(request.resource.data) == 'draft'
        && validVerificationApplicationNumber(request.resource.data);

      allow update: if isRCAdmin()
        && resource.data.rcId == request.auth.uid
        && request.resource.data.rcId == resource.data.rcId
        && verificationRecordStatus(request.resource.data) != 'approved'
        && verificationRecordStatus(resource.data) == 'draft'
        && verificationRecordStatus(request.resource.data) in ['draft', 'submitted']
        && verificationApplicationNumberUnchanged()
        && (!rvSubmitRequiresZohoCustomer(request.resource.data) || rcHasZohoCustomerId(resource.data.rcId))
        && verificationZohoFieldsUnchanged();

      allow update: if isOperationalVct()
        && resource.data.rcId == vctRcId()
        && request.resource.data.rcId == resource.data.rcId
        && vctOwnsVerification(resource.data)
        && verificationRecordStatus(request.resource.data) != 'approved'
        && verificationRecordStatus(resource.data) == 'draft'
        && verificationRecordStatus(request.resource.data) in ['draft', 'submitted']
        && verificationApplicationNumberUnchanged()
        && (!rvSubmitRequiresZohoCustomer(request.resource.data) || rcHasZohoCustomerId(resource.data.rcId))
        && verificationZohoFieldsUnchanged();

      // Certificate worker — RC approves own submitted verification after DOCA success.
      allow update: if isRCAdmin()
        && resource.data.rcId == request.auth.uid
        && request.resource.data.rcId == resource.data.rcId
        && verificationRecordStatus(resource.data) == 'submitted'
        && verificationRecordStatus(request.resource.data) == 'approved'
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['status', 'approvedAt', 'updatedAt']);

      allow delete: if isRCAdmin()
        && resource.data.rcId == request.auth.uid
        && verificationRecordStatus(resource.data) == 'draft';

      allow delete: if isOperationalVct()
        && resource.data.rcId == vctRcId()
        && vctOwnsVerification(resource.data)
        && verificationRecordStatus(resource.data) == 'draft';
    }

    // ── internal counters (verification application numbers) ─────
    match /_counters/{counterId} {
      function isVerificationApplicationCounter() {
        return counterId.matches('verificationApplicationNumber_[0-9]{2}');
      }

      allow read: if isSuperAdmin() && isVerificationApplicationCounter();

      allow read: if isAuthenticated()
        && (isRCAdmin() || isOperationalVct())
        && isVerificationApplicationCounter();

      allow create: if isAuthenticated()
        && (isRCAdmin() || isOperationalVct())
        && isVerificationApplicationCounter()
        && request.resource.data.keys().hasOnly(['nextSeq', 'year'])
        && request.resource.data.nextSeq is int
        && request.resource.data.nextSeq >= 2
        && request.resource.data.year is int;

      allow create: if isSuperAdmin();

      allow update: if isAuthenticated()
        && (isRCAdmin() || isOperationalVct())
        && isVerificationApplicationCounter()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['nextSeq', 'year'])
        && request.resource.data.nextSeq is int
        && request.resource.data.nextSeq > resource.data.nextSeq
        && request.resource.data.year is int;

      allow update: if isSuperAdmin();
    }

    // ── app settings (global toggles) ─────────────────────────────
    match /appSettings/{docId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // ── certificate automation worker (remote control + telemetry) ─
    match /automationWorker/{docId} {
      allow read, write: if isSuperAdmin();
    }

    match /automationWorkerLogs/{logId} {
      allow read, create: if isSuperAdmin();
      allow update, delete: if false;
    }

    match /automationWorkerCaptchaAttempts/{attemptId} {
      allow read, create: if isSuperAdmin();
      allow update, delete: if false;
    }

    match /automationWorkerSessions/{sessionId} {
      allow read, create: if isSuperAdmin();
      allow update, delete: if false;
    }

    match /docaCertificates/{certId} {
      allow read, write: if isSuperAdmin();
    }

    function canReadRcWallet(rcId) {
      return isSuperAdmin()
        || (isRCAdmin() && request.auth.uid == rcId)
        || (isOperationalVct() && vctRcId() == rcId);
    }

    // ── RC wallet balance (mutations via Cloud Functions only) ────
    match /rcWallets/{rcId} {
      allow read: if canReadRcWallet(rcId);
      allow write: if false;
    }

    match /walletTopUps/{topUpId} {
      allow read: if isSuperAdmin()
        || (isRCAdmin() && resource.data.rcId == request.auth.uid)
        || (isOperationalVct() && resource.data.rcId == vctRcId());

      allow create: if isRCAdmin()
        && request.resource.data.rcId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.amountInr is number
        && request.resource.data.amountInr > 0
        && request.resource.data.submittedByUid == request.auth.uid
        && request.resource.data.submittedAt is string
        && request.resource.data.keys().hasOnly([
          'rcId',
          'rcCompanyName',
          'amountInr',
          'status',
          'screenshotUrl',
          'screenshotPath',
          'screenshotName',
          'screenshotContentType',
          'note',
          'submittedAt',
          'submittedByUid',
        ]);

      allow update, delete: if false;
    }

    match /walletLedger/{entryId} {
      allow read: if isSuperAdmin()
        || (isRCAdmin() && resource.data.rcId == request.auth.uid)
        || (isOperationalVct() && resource.data.rcId == vctRcId());
      allow write: if false;
    }
  }
}
