rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function role() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function validAadhar(data) {
      return data.aadhar is string && data.aadhar.size() == 12;
    }

    function validAadharId(aadhar) {
      return aadhar is string && aadhar.size() == 12;
    }

    function isAuthenticated() { return request.auth != null; }
    function isSuperAdmin()    { return isAuthenticated() && role() == 'super_admin'; }
    function isRCAdmin()       { return isAuthenticated() && role() == 'rc_admin'; }
    function isVCT()           { return isAuthenticated() && role() == 'vct'; }

    function vctApprovalStatus(data) {
      return data.get('approvalStatus', 'approved');
    }

    // ── users ─────────────────────────────────────────────────────
    match /users/{uid} {

      allow get: if isAuthenticated() && request.auth.uid == uid;

      allow read, write: if isSuperAdmin();

      allow read: if isRCAdmin()
        && resource.data.role == 'vct'
        && resource.data.rcId == request.auth.uid;

      allow create: if isAuthenticated()
        && request.auth.uid == uid
        && validAadhar(request.resource.data);

      allow create: if isRCAdmin()
        && request.resource.data.role == 'vct'
        && request.resource.data.rcId == request.auth.uid
        && validAadhar(request.resource.data)
        && request.resource.data.approvalStatus == 'pending';

      allow update: if isRCAdmin()
        && resource.data.role == 'vct'
        && resource.data.rcId == request.auth.uid
        && request.resource.data.role == 'vct'
        && request.resource.data.rcId == request.auth.uid
        && request.resource.data.aadhar == resource.data.aadhar
        && validAadhar(request.resource.data)
        && vctApprovalStatus(request.resource.data) == vctApprovalStatus(resource.data)
        && request.resource.data.get('approvedAt', null) == resource.data.get('approvedAt', null)
        && request.resource.data.get('approvedByUid', null) == resource.data.get('approvedByUid', null);

      allow delete: if isRCAdmin()
        && resource.data.role == 'vct'
        && resource.data.rcId == request.auth.uid
        && vctApprovalStatus(resource.data) == 'pending';
    }

    // ── aadharIndex (global duplicate Aadhar lookup) ───────────────
    match /aadharIndex/{aadhar} {
      allow get: if isSuperAdmin() || isRCAdmin();

      allow create: if validAadharId(aadhar)
        && (isSuperAdmin() || isRCAdmin())
        && request.resource.data.uid is string
        && request.resource.data.role is string;

      allow delete: if isSuperAdmin() || isRCAdmin();
    }

    // ── rcVcts (RC technician roster index) ───────────────────────
    match /rcVcts/{rcId} {
      allow read, write: if isSuperAdmin();

      match /members/{vctUid} {
        allow read, write: if isSuperAdmin();
        allow read: if isRCAdmin() && request.auth.uid == rcId;
        allow create: if isRCAdmin() && request.auth.uid == rcId;
        allow update: if isRCAdmin() && request.auth.uid == rcId;
        allow delete: if isRCAdmin()
          && request.auth.uid == rcId
          && vctApprovalStatus(resource.data) == 'pending';
      }
    }

    function isAdminManagedProduct() {
      return !('managedByRole' in resource.data)
        || resource.data.managedByRole == 'super_admin';
    }

    // ── products ──────────────────────────────────────────────────
    match /products/{productId} {
      allow list: if isAuthenticated();
      allow get: if isSuperAdmin()
        || (isAuthenticated() && isAdminManagedProduct());
      allow create, update, delete: if isSuperAdmin();
    }

    // ── jobs ───────────────────────────────────────────────────────────
    match /jobs/{jobId} {
      allow read:   if isAuthenticated();
      allow create: if isSuperAdmin() || isRCAdmin();
      allow update: if isAuthenticated();
      allow delete: if isSuperAdmin();
    }

    // ── certificates ───────────────────────────────────────────────
    match /certificates/{certId} {
      allow read:  if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // ── vehicles (RC-managed) ─────────────────────────────────────
    match /vehicles/{vehicleId} {
      allow read, write: if isSuperAdmin();

      allow read: if isRCAdmin() && resource.data.rcId == request.auth.uid;

      allow create: if isRCAdmin()
        && request.resource.data.rcId == request.auth.uid;

      allow update: if isRCAdmin()
        && resource.data.rcId == request.auth.uid
        && request.resource.data.rcId == request.auth.uid;

      // RC cannot delete vehicles once registered; Super Admin may remove records.
    }

    // ── customers (RC-managed) ────────────────────────────────────
    match /customers/{customerId} {
      allow read, write: if isSuperAdmin();

      allow read: if isRCAdmin() && resource.data.rcId == request.auth.uid;

      allow create: if isRCAdmin()
        && request.resource.data.rcId == request.auth.uid;

      allow update: if isRCAdmin()
        && resource.data.rcId == request.auth.uid
        && request.resource.data.rcId == request.auth.uid;

      allow delete: if isRCAdmin()
        && resource.data.rcId == request.auth.uid;
    }

    // ── site calibrations (RC-managed) ────────────────────────────
    match /siteCalibrations/{recordId} {
      allow read, write: if isSuperAdmin();

      allow read: if isRCAdmin() && resource.data.rcId == request.auth.uid;

      allow create: if isRCAdmin()
        && request.resource.data.rcId == request.auth.uid;

      allow update: if isRCAdmin()
        && resource.data.rcId == request.auth.uid
        && request.resource.data.rcId == request.auth.uid;

      allow delete: if isRCAdmin()
        && resource.data.rcId == request.auth.uid;
    }
  }
}
