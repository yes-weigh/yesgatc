# WeatherAPI.com — prefill ambient temperature & humidity on verification forms.
VITE_WEATHERAPI_KEY=a2434eee652f40bcb85104654262605

# Google Maps Geocoding API — photo stamp place names (same data as Google Maps).
# Enable "Geocoding API" in Google Cloud Console; restrict key to your site + Geocoding API only.
# Local dev: set here. Production: add the same values as GitHub Actions repository secrets
# (Settings → Secrets and variables → Actions) — Vite bakes them in at `npm run build` in CI.
VITE_GOOGLE_MAPS_API_KEY=
